<h1>Flight Booker</h1>

<%= form_with url:"/flights/", method: "get", local: true do |f| %>
    <div>
        <%= f.label "Depature Airport:",:departure_airport %>
        <%= select_tag(:departure_airport, options_from_collection_for_select(@departure_airports, :id, :airport_code))%>
    </div>
    <div>
        <%= f.label "Arrival Airport:",:arrival_airport %>
        <%= select_tag(:arrival_airport, options_from_collection_for_select(@arrival_airports, :id, :airport_code))%>
    </div>
    <div>
        <%= f.label "Date:", :date %>
        <%= select_tag(:date, options_for_select(@date.map { |f| [f.date.strftime("%B %d, %Y"), f.date.to_date] })) %>
    </div>
    <div>
        <%= f.label "Pasesengers:", :num_tickets%>
        <%= select_tag(:num_tickets, options_for_select(1..4, params[:num_tickets]))%>
    </div>
    <%= submit_tag "Find Flights"%>
<% end %>
<pre><%= params.inspect %></pre>

<%= render "result" %>